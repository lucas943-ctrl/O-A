def digitar_multilinha(texto: str) -> None:
    linhas = texto.split("\n")

    for i, linha in enumerate(linhas):
        try:
            pyautogui.write(linha, interval=0.02)

            if i < len(linhas) - 1:
                pyautogui.press("enter")
                time.sleep(0.1)

        except pyautogui.FailSafeException:
            log_erro("PyAutoGUI fail-safe acionado durante digitacao multiline.")
            screenshot_debug("failsafe_digitar_multilinha")
            raise

        except Exception as e:
            log_erro(f"Falha ao digitar texto multiline: {e}")
            screenshot_debug("erro_digitar_multilinha")
            raise


