def montar_itens(df_excel: pd.DataFrame, df_query: pd.DataFrame) -> list[dict]:
    itens = []
    placas_sem_pj: dict[str, int] = {}
    placas_match_sem_pj: dict[str, int] = {}
    ignoradas_por_data = 0

    for _, linha_excel in df_excel.iterrows():
        placa_normalizada = linha_excel["placa_normalizada"]
        placa_original = valor_texto(linha_excel["placa"])
        data_avistamento = valor_texto(linha_excel["data_avistamento"])

        if not placa_normalizada:
            continue

        if not data_item_permitida(data_avistamento):
            ignoradas_por_data += 1
            continue

        matches = df_query[
            df_query["caracteristicas_normalizada"].str.contains(
                placa_normalizada,
                na=False,
                regex=False
            )
        ].copy()

        if matches.empty:
            placas_sem_pj[placa_original] = placas_sem_pj.get(placa_original, 0) + 1
            continue

        encontrou_pj_valido = False

        for _, match in matches.iterrows():
            pj = valor_texto(match.get("pj", ""))

            if not pj:
                continue

            encontrou_pj_valido = True

            item = {
                "pj": pj,
                "placa": placa_original,
                "data_avistamento": data_avistamento,
                "sigla": valor_texto(linha_excel["sigla"]),
                "logradouro": valor_texto(linha_excel["logradouro"]),
                "numero": valor_texto(linha_excel["numero"]),
                "bairro": valor_texto(linha_excel["bairro"]),
                "cidade": valor_texto(linha_excel["cidade"]),
                "latitude": normalizar_decimal(linha_excel["latitude"]),
                "longitude": normalizar_decimal(linha_excel["longitude"]),
                "localizador": valor_texto(linha_excel["localizador"]),
                "email": valor_texto(linha_excel["email"]),
                "whatsapp": valor_texto(linha_excel["whatsapp"]),
            }

            itens.append(item)

        if not encontrou_pj_valido:
            placas_match_sem_pj[placa_original] = placas_match_sem_pj.get(placa_original, 0) + 1

    log_info(f"Linhas ignoradas por filtro de data em montar_itens: {ignoradas_por_data}")

    total_sem_pj = sum(placas_sem_pj.values())
    total_match_sem_pj = sum(placas_match_sem_pj.values())

    if total_sem_pj:
        top_sem_pj = sorted(placas_sem_pj.items(), key=lambda x: (-x[1], x[0]))[:20]
        resumo = ", ".join(f"{placa} ({qtd})" for placa, qtd in top_sem_pj)
        log_info(
            f"Linhas sem PJ encontrado: {total_sem_pj} | placas unicas={len(placas_sem_pj)} | top20={resumo}"
        )

    if total_match_sem_pj:
        top_match_sem_pj = sorted(placas_match_sem_pj.items(), key=lambda x: (-x[1], x[0]))[:20]
        resumo = ", ".join(f"{placa} ({qtd})" for placa, qtd in top_match_sem_pj)
        log_info(
            f"Matches sem PJ valido: {total_match_sem_pj} | placas unicas={len(placas_match_sem_pj)} | top20={resumo}"
        )

    return itens


def remover_itens_duplicados(itens: list[dict]) -> list[dict]:
    vistos = set()
    itens_unicos = []

    for item in itens:
        chave = (
            valor_texto(item.get("pj")),
            valor_texto(item.get("placa")),
