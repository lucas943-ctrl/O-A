def carregar_excel(caminho_arquivo: str) -> pd.DataFrame:
    if not os.path.exists(caminho_arquivo):
        raise FileNotFoundError(f"Arquivo nao encontrado: {caminho_arquivo}")

    if not os.access(caminho_arquivo, os.R_OK):
        raise PermissionError(f"Sem permissao de leitura no arquivo: {caminho_arquivo}")

    df = pd.read_excel(caminho_arquivo, engine="openpyxl")
    df.columns = [str(col).strip() for col in df.columns]

    col_placa = encontrar_coluna(df, "placa")
    col_data = encontrar_coluna(df, "data avistamento", "data_avistamento", "data/hora", "data hora")
    col_sigla = encontrar_coluna(df, "sigla")
    col_logradouro = encontrar_coluna(df, "logradouro")
    col_numero = encontrar_coluna(df, "numero", "número")
    col_bairro = encontrar_coluna(df, "bairro")
    col_cidade = encontrar_coluna(df, "cidade")
    col_latitude = encontrar_coluna(df, "latitude")
    col_longitude = encontrar_coluna(df, "longitude")
    col_localizador = encontrar_coluna(df, "localizador")
    col_email = encontrar_coluna(df, "email", "e-mail")
    col_whatsapp = encontrar_coluna(df, "whatsapp", "telefone", "celular")

    df_result = pd.DataFrame({
        "placa": df[col_placa].apply(valor_texto),
        "data_avistamento": df[col_data].apply(valor_texto),
        "sigla": df[col_sigla].apply(valor_texto),
        "logradouro": df[col_logradouro].apply(valor_texto),
        "numero": df[col_numero].apply(valor_texto),
        "bairro": df[col_bairro].apply(valor_texto),
        "cidade": df[col_cidade].apply(valor_texto),
        "latitude": df[col_latitude].apply(normalizar_decimal),
        "longitude": df[col_longitude].apply(normalizar_decimal),
        "localizador": df[col_localizador].apply(valor_texto),
        "email": df[col_email].apply(valor_texto),
        "whatsapp": df[col_whatsapp].apply(valor_texto),
    })

    df_result["placa_normalizada"] = df_result["placa"].apply(normalizar_texto)
    return df_result


def remover_avistamentos_duplicados(df_excel: pd.DataFrame) -> pd.DataFrame:
    df = df_excel.copy()

    df["chave_avistamento"] = (
        df["placa_normalizada"].apply(valor_texto)
        + "|"
        + df["data_avistamento"].apply(normalizar_data_hora_minuto)
    )

    total_antes = len(df)
    df = df.drop_duplicates(subset=["chave_avistamento"], keep="first").copy()
    total_depois = len(df)
    total_removidos = total_antes - total_depois

    log_info(
        f"Avistamentos duplicados removidos: {total_removidos} | antes={total_antes} | depois={total_depois}"
    )

    return df.drop(columns=["chave_avistamento"])


