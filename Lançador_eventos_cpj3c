def localizar_box(
    img: Path,
    desc: str,
    timeout: int = 10,
    confidence: float = 0.70,
    region=None,
):
    fim = time.time() + timeout
    ultimo_erro = None
    tentativa = 0

    try:
        import cv2  # noqa: F401
        tem_opencv = True
    except Exception:
        tem_opencv = False

    while time.time() < fim:
        tentativa += 1
        log_tentativa(f"Localizando box: {desc}", tentativa, max(1, int(timeout / 0.4)))

        try:
            kwargs = {
                "image": str(img),
                "grayscale": True,
                "region": region,
            }
            if tem_opencv:
                kwargs["confidence"] = confidence

            box = pyautogui.locateOnScreen(**kwargs)

            if box:
                log_info(
                    f"Box localizado: {desc} | left={box.left}, top={box.top}, width={box.width}, height={box.height}"
                )
                return box

        except pyautogui.ImageNotFoundException as e:
            ultimo_erro = e
        except Exception as e:
            ultimo_erro = e

        time.sleep(0.4)

    log_info(f"Box nao localizado: {desc} | erro={ultimo_erro}")
    return None


def localizar_ponto(
    img: Path,
    desc: str,
    timeout: int = 10,
    confidence: float = 0.70,
    region=None,
):
    fim = time.time() + timeout
    ultimo_erro = None
