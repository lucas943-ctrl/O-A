def main():
    pjs_concluidos: list[str] = []

    try:
        log_info(f"VERSAO_SCRIPT: {VERSAO_SCRIPT}")
        log_info(f"Inicio: {LOG_FILE}")
        log_info(f"DATA_INICIO_PROCESSAMENTO: {DATA_INICIO_PROCESSAMENTO}")

        validar_credenciais()
        validar_arquivos()

        df_excel = carregar_excel(ARQUIVO_EXCEL)
        df_excel = remover_avistamentos_duplicados(df_excel)

        df_query = carregar_dados_banco()
        itens = montar_itens(df_excel, df_query)
        log_info(f"Total de itens candidatos antes da remocao de duplicados: {len(itens)}")

        itens = remover_itens_duplicados(itens)
        log_info(f"Total de itens candidatos antes da validacao de ja lancados: {len(itens)}")

        df_eventos_lancados = carregar_eventos_lancados()
        itens = remover_itens_ja_lancados(itens, df_eventos_lancados)

        if not itens:
            log_info("Nenhum item restante para lancar apos a validacao.")
            return

        validar_itens(itens)

        log_info(f"Total de itens prontos para automacao: {len(itens)}")

        abrir_cpj()
        fazer_login()

        tratar_popup_cadastro_lembretes()

        if aguardar_popup(IMG_NOTIFICACAO_TITULO, "notificacao", CONFIDENCE_TITULO, timeout=8):
            fechar_notificacao_por_ancora()

        if aguardar_popup(IMG_POPUP_CONFIRMA_TITULO, "confirma", CONFIDENCE_CONFIRMA, timeout=8):
            tratar_popup_confirma()

        if not clicar_icone_pastinha():
            log_erro("Nao conseguiu clicar no icone da pastinha")
            return

        pjs_concluidos = processar_lista_itens(itens)

        total_concluidos = len(pjs_concluidos)
        total_pjs_unicos_concluidos = len(set(pjs_concluidos))
        contador_pj = Counter(pjs_concluidos)

        top_repetidos = ", ".join(
            f"{pj} ({qtd})"
            for pj, qtd in contador_pj.most_common(20)
        )

        log_info(f"Total de lancamentos concluidos com sucesso: {total_concluidos}")
        log_info(f"Total de PJs unicos concluidos com sucesso: {total_pjs_unicos_concluidos}")

        if top_repetidos:
            log_info(f"PJs concluidos mais frequentes (top 20): {top_repetidos}")

        log_info("Fim")

    except Exception as e:
        total_concluidos = len(pjs_concluidos)
        total_pjs_unicos_concluidos = len(set(pjs_concluidos))

        screenshot_debug("erro_automacao")
        log_erro(
            f"Erro nao tratado: {e} | "
            f"sucessos_ate_erro={total_concluidos} | "
            f"pjs_unicos_ate_erro={total_pjs_unicos_concluidos}"
        )
        raise


if __name__ == "__main__":
    main()
