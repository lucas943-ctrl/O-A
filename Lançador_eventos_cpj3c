def aguardar_popup(img_titulo: Path, desc: str, confidence: float, timeout: int = 8) -> bool:
    tentativas_totais = max(1, int(timeout / 1.5))

    for tentativa in range(1, tentativas_totais + 1):
        log_tentativa(f"Aguardando popup '{desc}'", tentativa, tentativas_totais)

        box = localizar_box(
            img_titulo,
            f"espera do popup: {desc}",
            timeout=1,
            confidence=confidence,
            region=obter_regiao_popup(),
        )
        if box:
            log_info(f"Popup '{desc}' apareceu.")
            return True

        time.sleep(0.5)

    log_info(f"Popup '{desc}' nao apareceu dentro do tempo limite.")
    return False


