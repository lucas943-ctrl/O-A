        abortar("USERNAME vazio.")
    if not PASSWORD.strip():
        abortar("PASSWORD vazio.")


def validar_itens(itens: list[dict]) -> None:
    if not itens:
        abortar("A lista de itens esta vazia apos cruzar planilha com banco.")

    campos_necessarios = [
        "pj",
        "placa",
        "data_avistamento",
        "sigla",
    ]

    for i, item in enumerate(itens, start=1):
        for campo in campos_necessarios:
            if campo not in item:
                abortar(f"Item {i} nao contem a chave '{campo}'.")
            if not valor_texto(item[campo]):
                abortar(f"Item {i} possui o campo obrigatorio '{campo}' vazio.")


def validar_arquivos() -> None:
    for arquivo in [
        IMG_NOTIFICACAO_TITULO,
        IMG_ICONE_PASTINHA,
        IMG_POPUP_CONFIRMA_TITULO,
        IMG_POPUP_LEMBRETES_TITULO,
        IMG_POPUP_CADASTRO_LEMBRETES_TITULO,
        IMG_TELA_PESQUISA_PJ,
    ]:
        if not arquivo.exists():
            abortar(f"Arquivo nao encontrado: {arquivo}")
        if arquivo.stat().st_size == 0:
            abortar(f"Arquivo vazio: {arquivo}")
    log_info("Imagens OK")


