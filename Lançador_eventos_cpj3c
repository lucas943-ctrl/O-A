def carregar_dados_banco() -> pd.DataFrame:
    conn = mysql.connector.connect(**DB_CONFIG)
    cursor = conn.cursor(dictionary=True)

    try:
        cursor.execute(QUERY)
        dados = cursor.fetchall()
    finally:
        cursor.close()
        conn.close()

    df = pd.DataFrame(dados)

    if df.empty:
        df = pd.DataFrame(columns=[
            "pj", "ficha", "acao", "valor_causa", "descricao", "caracteristicas"
        ])

    if "caracteristicas" not in df.columns:
        df["caracteristicas"] = ""

    df["caracteristicas"] = df["caracteristicas"].fillna("").astype(str)
    df["caracteristicas_normalizada"] = df["caracteristicas"].apply(normalizar_texto)

    return df


def carregar_eventos_lancados() -> pd.DataFrame:
    conn = mysql.connector.connect(**DB_CONFIG)
    cursor = conn.cursor(dictionary=True)

    try:
        cursor.execute(QUERY_EVENTOS_LANCADOS)
        dados = cursor.fetchall()
    finally:
        cursor.close()
        conn.close()

    df = pd.DataFrame(dados)

    if df.empty:
        df = pd.DataFrame(columns=["pj", "evento", "texto"])

    if "texto" not in df.columns:
        df["texto"] = ""

    df["pj"] = df["pj"].apply(valor_texto)
    df["evento"] = df["evento"].apply(valor_texto)
    df["texto_comparacao"] = df["texto"].apply(normalizar_texto_exato_evento)

    chaves = [
        (valor_texto(linha["pj"]), valor_texto(linha["texto_comparacao"]))
        for _, linha in df.iterrows()
        if valor_texto(linha["pj"]) and valor_texto(linha["texto_comparacao"])
    ]

    total_chaves_unicas = len(set(chaves))

    log_info(
        f"Total de eventos lancados carregados do banco: {len(df)} | "
        f"chaves_unicas_pj_texto={total_chaves_unicas}"
    )

    duplicados = (
        df.groupby(["pj", "texto_comparacao"])
        .size()
        .reset_index(name="qtd")
        .sort_values(["qtd", "pj"], ascending=[False, True])
    )

    duplicados_reais = duplicados[duplicados["qtd"] > 1].copy()

    if not duplicados_reais.empty:
        top = duplicados_reais.head(20)
        resumo = " | ".join(
            f"pj={valor_texto(linha['pj'])} qtd={int(linha['qtd'])}"
            for _, linha in top.iterrows()
        )
        log_info(
            f"Eventos lancados repetidos na query (top 20): {resumo} | "
            f"total_repetidos={len(duplicados_reais)}"
        )

    return df


