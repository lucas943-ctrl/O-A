def processar_lista_itens(itens: list[dict]) -> list[str]:
    total = len(itens)
    pjs_concluidos: list[str] = []

    for indice, item in enumerate(itens, start=1):
        pj = str(item["pj"]).strip()
        placa = str(item["placa"]).strip()
        sigla = str(item["sigla"]).strip()
        observacao = montar_observacao_evento(item)

        log_info(
            f"Processando item {indice} de {total} | pj={pj} | placa={placa} | sigla={sigla}"
        )

        try:
            abriu = pesquisar_processo(pj)
            if not abriu:
                log_erro(f"Nao foi possivel abrir o processo {pj}.")
                continue

            tratar_popup_cadastro_lembretes()
            tratar_popup_lembretes()

            if not abrir_novo_evento():
                log_erro(f"Falha ao abrir novo evento | pj={pj}")
                voltar_para_pesquisa()
                continue

            if not preencher_sigla_evento(sigla):
                log_erro(f"Falha ao preencher sigla | pj={pj} | sigla={sigla}")
                voltar_para_pesquisa()
                continue

            if not preencher_observacao_evento(observacao):
                log_erro(f"Falha ao preencher observacao | pj={pj}")
                voltar_para_pesquisa()
                continue

            if not clicar_botao_salvar():
                log_erro(f"Falha ao salvar evento | pj={pj}")
                voltar_para_pesquisa()
                continue

            voltar_para_pesquisa()
            pjs_concluidos.append(pj)

            total_concluidos = len(pjs_concluidos)
            total_pjs_unicos = len(set(pjs_concluidos))

            log_info(
                f"Lancamento concluido para o processo {pj} | "
                f"sucessos={total_concluidos} | pjs_unicos={total_pjs_unicos}"
            )

        except pyautogui.FailSafeException:
            log_erro(
                f"PyAutoGUI fail-safe acionado | pj={pj} | "
                f"sucessos_ate_agora={len(pjs_concluidos)} | "
                f"pjs_unicos_ate_agora={len(set(pjs_concluidos))}"
            )
            screenshot_debug("failsafe_processar_item")
            raise

        except Exception as e:
            log_erro(
                f"Erro ao processar item | pj={pj} | placa={placa} | sigla={sigla} | erro={e}"
            )
            screenshot_debug("erro_processar_item")

            try:
                voltar_para_pesquisa()
            except Exception as erro_volta:
                log_erro(f"Falha ao tentar voltar para pesquisa apos erro | pj={pj} | erro={erro_volta}")

            continue

    return pjs_concluidos


