def montar_observacao_evento(item: dict) -> str:
    campos = [
        ("Placa", valor_texto(item["placa"])),
        ("Data avistamento", formatar_data_evento(item["data_avistamento"])),
        ("Logradouro", valor_texto(item["logradouro"])),
        ("Numero", valor_texto(item["numero"])),
        ("Bairro", valor_texto(item["bairro"])),
        ("Cidade", valor_texto(item["cidade"])),
        ("Latitude", normalizar_decimal(item["latitude"])),
        ("Longitude", normalizar_decimal(item["longitude"])),
        ("Localizador", valor_texto(item["localizador"])),
        ("Email", valor_texto(item["email"])),
        ("Whatsapp", valor_texto(item["whatsapp"])),
    ]

    linhas = []
    for nome, valor in campos:
        linhas.append(f"| {nome}: {valor}")

    return "\n".join(linhas)


def remover_itens_ja_lancados(itens: list[dict], df_eventos_lancados: pd.DataFrame) -> list[dict]:
    if not itens:
        return itens

    if df_eventos_lancados.empty:
        log_info("Nenhum evento anterior encontrado no banco para validacao.")
        return itens

    chaves_existentes = set()

    for _, linha in df_eventos_lancados.iterrows():
        pj = valor_texto(linha.get("pj"))
        texto = valor_texto(linha.get("texto_comparacao"))

        if pj and texto:
            chaves_existentes.add((pj, texto))

    total_itens_com_chave = 0
    total_matches = 0
    itens_filtrados = []
    exemplos_ignorados = 0
    exemplos_nao_match = 0

    for item in itens:
        pj = valor_texto(item.get("pj"))
        texto_montado = montar_observacao_evento(item)
        texto_montado_cmp = normalizar_texto_exato_evento(texto_montado)

        if pj and texto_montado_cmp:
            total_itens_com_chave += 1

        chave_item = (pj, texto_montado_cmp)

        if chave_item in chaves_existentes:
            total_matches += 1

            if exemplos_ignorados < 20:
                log_info(
                    f"Item ignorado por ja estar lancado | "
                    f"pj={pj} | placa={valor_texto(item.get('placa'))} | sigla={valor_texto(item.get('sigla'))}"
                )
                exemplos_ignorados += 1

            continue

        if exemplos_nao_match < 10:
            mesmos_pjs = df_eventos_lancados[df_eventos_lancados["pj"] == pj].copy()

            if not mesmos_pjs.empty:
                log_info(
                    f"NAO_MATCH_COM_PJ_EXISTENTE | "
                    f"pj={pj} | placa={valor_texto(item.get('placa'))} | sigla={valor_texto(item.get('sigla'))}"
                )
                log_info(f"TEXTO_ITEM >>> {texto_montado_cmp}")

                for idx, (_, linha_pj) in enumerate(mesmos_pjs.head(3).iterrows(), start=1):
                    log_info(f"TEXTO_BANCO_{idx} >>> {valor_texto(linha_pj.get('texto_comparacao'))}")

                exemplos_nao_match += 1

        itens_filtrados.append(item)

    log_info(
        f"Resumo validacao ja lancados | "
        f"itens_com_chave={total_itens_com_chave} | "
        f"chaves_existentes={len(chaves_existentes)} | "
        f"matches={total_matches} | "
        f"antes={len(itens)} | depois={len(itens_filtrados)}"
    )

    return itens_filtrados


