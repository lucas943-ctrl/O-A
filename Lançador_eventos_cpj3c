def valor_texto(valor) -> str:
    if pd.isna(valor):
        return ""
    texto = str(valor).strip()
    if texto.lower() == "nan":
        return ""
    return texto


def normalizar_texto(texto) -> str:
    texto = valor_texto(texto).upper()
    texto = re.sub(r"[^A-Z0-9]", "", texto)
    return texto


def normalizar_decimal(valor) -> str:
    return valor_texto(valor).replace(",", ".")


def converter_para_datetime(valor):
    texto = valor_texto(valor)
    if not texto:
        return pd.NaT

    formatos = [
        "%d/%m/%Y %H:%M:%S",
        "%d/%m/%Y %H:%M",
        "%d/%m/%Y",
        "%Y-%m-%d %H:%M:%S",
        "%Y-%m-%d %H:%M",
        "%Y-%m-%d",
    ]

    for formato in formatos:
        try:
            return pd.to_datetime(texto, format=formato, errors="raise")
        except Exception:
            pass

    return pd.to_datetime(texto, errors="coerce", dayfirst=True)


def formatar_data_evento(valor) -> str:
    dt = converter_para_datetime(valor)

    if pd.isna(dt):
        return valor_texto(valor)

    return dt.strftime("%Y-%m-%d %H:%M:%S")


def normalizar_data_hora_minuto(valor) -> str:
    texto = valor_texto(valor)
    if not texto:
        return ""

    dt = converter_para_datetime(texto)
    if pd.isna(dt):
        return texto[:16]

    return dt.strftime("%Y-%m-%d %H:%M")


def data_item_permitida(valor_data: str) -> bool:
    data_inicio = converter_para_datetime(DATA_INICIO_PROCESSAMENTO)
    data_item = converter_para_datetime(valor_data)

    if pd.isna(data_inicio):
        abortar(f"DATA_INICIO_PROCESSAMENTO invalida: {DATA_INICIO_PROCESSAMENTO}")

    if pd.isna(data_item):
        log_info(f"Linha ignorada por data_avistamento invalida/vazia: {valor_texto(valor_data)}")
        return False

    return data_item >= data_inicio


def normalizar_nome_coluna(nome: str) -> str:
    nome = str(nome).strip().lower()
    nome = nome.replace("ã", "a").replace("á", "a").replace("à", "a").replace("â", "a")
    nome = nome.replace("é", "e").replace("ê", "e")
    nome = nome.replace("í", "i")
    nome = nome.replace("ó", "o").replace("ô", "o").replace("õ", "o")
    nome = nome.replace("ú", "u")
    nome = nome.replace("ç", "c")
    nome = re.sub(r"[^a-z0-9]+", "_", nome).strip("_")
    return nome


def normalizar_texto_exato_evento(texto) -> str:
    texto = valor_texto(texto)

    if not texto:
        return ""

    texto = texto.replace("\r\n", "\n").replace("\r", "\n")
    texto = "\n".join(linha.rstrip() for linha in texto.split("\n"))
    texto = texto.strip()

    texto = texto.encode("ascii", "ignore").decode("ascii")

    return texto.upper()


def encontrar_coluna(df: pd.DataFrame, *nomes_possiveis: str) -> str:
    mapa = {normalizar_nome_coluna(col): col for col in df.columns}

    for nome in nomes_possiveis:
        chave = normalizar_nome_coluna(nome)
        if chave in mapa:
            return mapa[chave]

    raise ValueError(
        f"Nao foi encontrada nenhuma das colunas esperadas {nomes_possiveis}. Colunas existentes: {list(df.columns)}"
    )


